{
  "version": 2,
  "rootDirectory": "frontend",
  "buildCommand": "yarn build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "env": {
    "REACT_APP_BACKEND_URL": "https://javaguardai-production.up.railway.app"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
