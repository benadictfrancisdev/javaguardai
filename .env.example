# Environment Variables for FrameworkGuard AI
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Supabase Configuration
# ===========================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# ===========================================
# REQUIRED - AI Configuration
# ===========================================
# Emergent LLM Key for Claude API access
EMERGENT_LLM_KEY=sk-emergent-your_key_here

# ===========================================
# OPTIONAL - Redis Configuration
# ===========================================
# For deduplication cache (defaults to local Redis in docker-compose)
REDIS_URL=redis://localhost:6379

# ===========================================
# OPTIONAL - Slack Alerts
# ===========================================
# Create an incoming webhook in Slack: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ===========================================
# OPTIONAL - Error Tracking (Sentry)
# ===========================================
# Get DSN from: https://sentry.io/settings/YOUR_ORG/projects/YOUR_PROJECT/keys/
SENTRY_DSN=

# ===========================================
# OPTIONAL - Application Settings
# ===========================================
# Environment: development | staging | production
ENV=development

# CORS origins (comma-separated for multiple)
CORS_ORIGINS=*

# ===========================================
# MONGODB (Legacy - Not used, kept for compatibility)
# ===========================================
MONGO_URL=mongodb://localhost:27017
DB_NAME=frameworkguard
